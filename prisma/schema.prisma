generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement()) @map("user_id")
  name           String          @db.VarChar(120)
  email          String          @unique @db.VarChar(255)
  passwordHash   String          @map("password_hash") @db.VarChar(255)
  role           UserRole        @default(STUDENT)
  createdAt      DateTime        @default(now()) @map("created_at")
  conversations  Conversation[]
  quizzes        Quiz[]
  sessions       Session[]
  studyProgress  StudyProgress?
  studyQuestions StudyQuestion[]
  systemLogs     SystemLog[]
  attachments    Attachment[]
}

model Session {
  id        Int       @id @default(autoincrement()) @map("session_id")
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
}

model StudyQuestion {
  id              Int      @id @default(autoincrement()) @map("question_id")
  userId          Int      @map("user_id")
  questionText    String   @map("question_text")
  chatbotResponse String   @map("chatbot_response")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([userId, createdAt])
}

model Quiz {
  id             Int            @id @default(autoincrement()) @map("quiz_id")
  userId         Int            @map("user_id")
  conversationId Int?           @map("conversation_id")
  quizTopic      String         @map("quiz_topic") @db.VarChar(200)
  score          Float?
  state          QuizState      @default(GENERATED)
  difficulty     QuizDifficulty @default(medium) @map("difficulty")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  answers        QuizAnswer[]
  questions      QuizQuestion[]

  @@index([userId])
  @@index([conversationId])
  @@index([userId, state])
  @@index([userId, quizTopic])
}

enum QuizDifficulty {
  easy
  medium
  hard
}

model QuizQuestion {
  id           Int          @id @default(autoincrement()) @map("quiz_question_id")
  quizId       Int          @map("quiz_id")
  questionText String       @map("question_text")
  position     Int
  answer       QuizAnswer?
  options      QuizOption[]
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([quizId, position])
  @@index([quizId])
}

model QuizOption {
  id              Int          @id @default(autoincrement()) @map("quiz_option_id")
  quizQuestionId  Int          @map("quiz_question_id")
  optionText      String       @map("option_text")
  position        Int
  isCorrect       Boolean      @map("is_correct")
  selectedAnswers QuizAnswer[]
  question        QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([quizQuestionId, position])
  @@index([quizQuestionId])
}

model QuizAnswer {
  id               Int          @id @default(autoincrement()) @map("quiz_answer_id")
  quizId           Int          @map("quiz_id")
  quizQuestionId   Int          @unique @map("quiz_question_id")
  selectedOptionId Int          @map("selected_option_id")
  isCorrect        Boolean      @map("is_correct")
  createdAt        DateTime     @default(now()) @map("created_at")
  quiz             Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quizQuestion     QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  selectedOption   QuizOption   @relation(fields: [selectedOptionId], references: [id], onUpdate: NoAction)

  @@index([quizId])
  @@index([selectedOptionId])
}

model StudyProgress {
  id              Int      @id @default(autoincrement()) @map("progress_id")
  userId          Int      @unique @map("user_id")
  completedTopics Int      @default(0) @map("completed_topics")
  totalQuizzes    Int      @default(0) @map("total_quizzes")
  averageScore    Float    @default(0) @map("average_score")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Conversation {
  id        Int       @id @default(autoincrement()) @map("conversation_id")
  userId    Int       @map("user_id")
  title     String    @db.VarChar(200)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages  Message[]
  quizzes   Quiz[]

  @@index([userId])
}

model SystemLog {
  id        Int      @id @default(autoincrement()) @map("log_id")
  userId    Int?     @map("user_id")
  action    String   @db.VarChar(100)
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([userId])
  @@index([createdAt])
}

model Attachment {
  id               String   @id @default(uuid()) @map("attachment_id")
  messageId        Int      @map("message_id")
  userId           Int      @map("user_id")
  originalName     String   @map("original_name")
  fileUrl          String   @map("file_url")
  mimeType         String   @map("mime_type")
  size             Int
  extractedText    String?  @map("extracted_text")
  createdAt        DateTime @default(now()) @map("created_at")
  
  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id])

  @@index([messageId])
  @@index([userId])
}

model Message {
  id             Int          @id @default(autoincrement()) @map("message_id")
  conversationId Int          @map("conversation_id")
  role           String       @db.VarChar(20)
  content        String
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attachments    Attachment[]

  @@index([conversationId])
}

enum QuizState {
  GENERATED
  COMPLETED
}

enum UserRole {
  STUDENT
  ADMIN
}
