generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DueDateKind {
  DATE_ONLY
  DATE_TIME
}

enum MessageAuthor {
  STUDENT
  ASSISTANT
}

enum SuggestedTaskState {
  PENDING
  CONFIRMED
  DISMISSED
}

model Student {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  timezone     String
  avatarColor  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions       Session[]
  courses        Course[]
  tasks          Task[]
  todayTasks     TodayTask[]
  conversations  Conversation[]
  messages       Message[]
  suggestedTasks SuggestedTask[]
}

model Session {
  id        String    @id @default(uuid())
  studentId String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([expiresAt])
}

model Course {
  id         String    @id @default(uuid())
  studentId  String
  name       String
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tasks         Task[]
  conversations Conversation[]
  suggestedTasks SuggestedTask[]

  @@index([studentId])
  @@index([studentId, archivedAt])
}

model Task {
  id          String       @id @default(uuid())
  studentId   String
  courseId    String?
  title       String
  notes       String?
  dueDateKind DueDateKind?
  dueDate     DateTime?    @db.Date
  dueAt       DateTime?
  completedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  todayTasks             TodayTask[]
  confirmedSuggestedTasks SuggestedTask[] @relation("CreatedTask")

  @@index([studentId])
  @@index([studentId, courseId])
  @@index([studentId, deletedAt])
  @@index([studentId, completedAt])
  @@index([studentId, deletedAt, completedAt, dueDate])
  @@index([studentId, deletedAt, completedAt, dueAt])
  @@index([dueDate])
  @@index([dueAt])
}

model TodayTask {
  id        String   @id @default(uuid())
  studentId String
  taskId    String
  day       DateTime @db.Date
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([studentId, taskId, day])
  @@index([studentId, day])
}

model Conversation {
  id        String    @id @default(uuid())
  studentId String
  courseId  String?
  title     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  messages       Message[]
  suggestedTasks SuggestedTask[]

  @@index([studentId])
  @@index([studentId, deletedAt])
  @@index([studentId, deletedAt, updatedAt])
}

model Message {
  id             String        @id @default(uuid())
  studentId      String
  conversationId String
  author         MessageAuthor
  content        String
  createdAt      DateTime      @default(now())

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([conversationId, createdAt])
}

model SuggestedTask {
  id             String             @id @default(uuid())
  studentId      String
  conversationId String
  courseId        String?
  createdTaskId  String?
  title          String
  notes          String?
  dueDateKind    DueDateKind?
  dueDate        DateTime?          @db.Date
  dueAt          DateTime?
  state          SuggestedTaskState @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  course       Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdTask  Task?        @relation("CreatedTask", fields: [createdTaskId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([conversationId])
  @@index([studentId, state])
  @@index([conversationId, state])
}
