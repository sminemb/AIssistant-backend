generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuizState {
  GENERATED
  COMPLETED
}

model Student {
  id           Int      @id @default(autoincrement()) @map("student_id")
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  sessions       Session[]
  studyQuestions StudyQuestion[]
  quizzes        Quiz[]
  studyProgress  StudyProgress?
}

model Session {
  id        Int       @id @default(autoincrement()) @map("session_id")
  studentId Int       @map("student_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([expiresAt])
}

model StudyQuestion {
  id              Int      @id @default(autoincrement()) @map("question_id")
  studentId       Int      @map("student_id")
  questionText    String   @map("question_text") @db.Text
  chatbotResponse String   @map("chatbot_response") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([studentId, createdAt])
}

model Quiz {
  id        Int       @id @default(autoincrement()) @map("quiz_id")
  studentId Int       @map("student_id")
  quizTopic String    @map("quiz_topic") @db.VarChar(200)
  score     Float?
  state     QuizState @default(GENERATED)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  answers   QuizAnswer[]

  @@index([studentId])
  @@index([studentId, state])
  @@index([studentId, quizTopic])
}

model QuizQuestion {
  id           Int    @id @default(autoincrement()) @map("quiz_question_id")
  quizId       Int    @map("quiz_id")
  questionText String @map("question_text") @db.Text
  position     Int

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuizOption[]
  answer  QuizAnswer?

  @@unique([quizId, position])
  @@index([quizId])
}

model QuizOption {
  id             Int     @id @default(autoincrement()) @map("quiz_option_id")
  quizQuestionId Int     @map("quiz_question_id")
  optionText     String  @map("option_text") @db.Text
  position       Int
  isCorrect      Boolean @map("is_correct")

  question       QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)
  selectedAnswers QuizAnswer[]

  @@unique([quizQuestionId, position])
  @@index([quizQuestionId])
}

model QuizAnswer {
  id               Int     @id @default(autoincrement()) @map("quiz_answer_id")
  quizId           Int     @map("quiz_id")
  quizQuestionId   Int     @unique @map("quiz_question_id")
  selectedOptionId Int     @map("selected_option_id")
  isCorrect        Boolean @map("is_correct")
  createdAt        DateTime @default(now()) @map("created_at")

  quiz           Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizQuestion   QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)
  selectedOption QuizOption   @relation(fields: [selectedOptionId], references: [id], onDelete: Restrict)

  @@index([quizId])
  @@index([selectedOptionId])
}

model StudyProgress {
  id              Int      @id @default(autoincrement()) @map("progress_id")
  studentId       Int      @unique @map("student_id")
  completedTopics Int      @default(0) @map("completed_topics")
  totalQuizzes    Int      @default(0) @map("total_quizzes")
  averageScore    Float    @default(0) @map("average_score")
  updatedAt       DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
